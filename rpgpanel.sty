%======================================================================================
%   RPGPANEL
%======================================================================================

\ProvidesExplPackage
    {rpgpanel}
    {2026-07-10}
    {0.1}
    {Unified tcolorbox panels for RPG typesetting}

%======================================================================================
%   SETUP

%--------------------------------------------------------------------------------------
%   REQUIRE

\RequirePackage{xparse}
\RequirePackage{l3keys2e}
\RequirePackage[breakable,skins]{tcolorbox}

\RequirePackage{rpgcolor}
\RequirePackage{rpgfont}

\ExplSyntaxOff
    \usetikzlibrary{calc}
\ExplSyntaxOn




%======================================================================================
%   DATA

%--------------------------------------------------------------------------------------
%   LOCALS

\tl_new:N  \l__rpg_panel_color_tl
\tl_new:N  \l__rpg_panel_title_tl
\tl_new:N  \l__rpg_panel_title_font_tl
\tl_new:N  \l__rpg_panel_body_font_tl
\tl_new:N  \l__rpg_panel_line_spread_tl
\tl_new:N  \l__rpg_panel_tcb_keys_tl
\tl_new:N  \l__rpg_panel_box_keys_tl
\bool_new:N \l__rpg_panel_title_bool




%======================================================================================
%   OPTIONS

%--------------------------------------------------------------------------------------
%   PANEL KEYS

\keys_define:nn { rpg / panel }
{
    style .choice:,
    style / plain .code:n =
        { \__rpg_panel_style_plain: },
    style / comment .code:n =
        { \__rpg_panel_style_comment: },
    style / sidebar .code:n =
        { \__rpg_panel_style_sidebar: },
    style / side-bar .code:n =
        { \__rpg_panel_style_sidebar: },
    style / narration .code:n =
        { \__rpg_panel_style_narration: },
    style / readaloud .code:n =
        { \__rpg_panel_style_narration: },
    style / read-aloud .code:n =
        { \__rpg_panel_style_narration: },
    style .value_required:n = true,

    variant .meta:n = { style = #1 },
    variant .value_required:n = true,

    color .tl_set:N = \l__rpg_panel_color_tl,
    color .value_required:n = true,

    title .code:n =
        {
            \tl_set:Nn \l__rpg_panel_title_tl {#1}
            \bool_set_true:N \l__rpg_panel_title_bool
        },
    title .value_required:n = true,

    title-font .tl_set:N = \l__rpg_panel_title_font_tl,
    title-font .value_required:n = true,

    body-font .tl_set:N = \l__rpg_panel_body_font_tl,
    body-font .value_required:n = true,

    fonttitle .meta:n = { title-font = #1 },
    fonttitle .value_required:n = true,

    fontupper .meta:n = { body-font = #1 },
    fontupper .value_required:n = true,

    line-spread .tl_set:N = \l__rpg_panel_line_spread_tl,
    line-spread .value_required:n = true,
}




%======================================================================================
%   CONTROL SEQUENCES

%--------------------------------------------------------------------------------------
%   STYLES

\cs_new_protected:Npn \__rpg_panel_style_plain:
{
    \tl_set:Nn \l__rpg_panel_color_tl { RPGColorPanelBackground }
    \tl_set:Nn \l__rpg_panel_title_font_tl { \RPGFontBody }
    \tl_set:Nn \l__rpg_panel_body_font_tl { \RPGFontBody }
    \tl_set:Nn \l__rpg_panel_line_spread_tl { 1 }
    \tl_clear:N \l__rpg_panel_tcb_keys_tl
}

\cs_new_protected:Npn \__rpg_panel_style_comment:
{
    \tl_set:Nn \l__rpg_panel_color_tl { RPGColorPanelBackground }
    \tl_set:Nn \l__rpg_panel_title_font_tl { \RPGFontCommentTitle }
    \tl_set:Nn \l__rpg_panel_body_font_tl { \RPGFontCommentBody }
    \tl_set:Nn \l__rpg_panel_line_spread_tl { .9 }
    \tl_set:Nn \l__rpg_panel_tcb_keys_tl
    {
        toptitle = 2pt,
        boxsep = 3pt,
        left = 6pt,
        right = 6pt,
        top = 0pt,
        bottom = 2pt,
        coltitle = RPGColorBody,
    }
}

\cs_new_protected:Npn \__rpg_panel_style_sidebar:
{
    \tl_set:Nn \l__rpg_panel_color_tl { RPGColorPanelBackground }
    \tl_set:Nn \l__rpg_panel_title_font_tl { \RPGFontSidebarTitle }
    \tl_set:Nn \l__rpg_panel_body_font_tl { \RPGFontSidebarBody }
    \tl_set:Nn \l__rpg_panel_line_spread_tl { .9 }
    \tl_set:Nn \l__rpg_panel_tcb_keys_tl
    {
        toptitle = 2pt,
        boxsep = 3pt,
        left = 6pt,
        right = 6pt,
        top = 0pt,
        bottom = 2pt,
        coltitle = RPGColorBody,
        borderline~north = {1pt} {-0.5pt} {RPGColorPanelAccent},
        borderline~south = {1pt} {-0.5pt} {RPGColorPanelAccent},
        fuzzy~shadow = {0mm} {-3.5pt} {-0.5pt} {0.4mm} {RPGColorPanelAccent!60!white},
        overlay =
        {
            \fill [RPGColorPanelAccent] ( frame.south~west ) -- ++ (  7pt, 0 ) -- ++ ( 0, -5pt ) -- cycle;
            \fill [RPGColorPanelAccent] ( frame.north~west ) -- ++ (  7pt, 0 ) -- ++ ( 0,  5pt ) -- cycle;
            \fill [RPGColorPanelAccent] ( frame.north~east ) -- ++ ( -7pt, 0 ) -- ++ ( 0,  5pt ) -- cycle;
            \fill [RPGColorPanelAccent] ( frame.south~east ) -- ++ ( -7pt, 0 ) -- ++ ( 0, -5pt ) -- cycle;
        },
    }
}

\cs_new_protected:Npn \__rpg_panel_style_narration:
{
    \tl_set:Nn \l__rpg_panel_color_tl { RPGColorPanelBackground }
    \tl_set:Nn \l__rpg_panel_title_font_tl { \RPGFontReadAloud }
    \tl_set:Nn \l__rpg_panel_body_font_tl { \RPGFontReadAloud }
    \tl_set:Nn \l__rpg_panel_line_spread_tl { 1.1 }
    \tl_set:Nn \l__rpg_panel_tcb_keys_tl
    {
        enhanced~jigsaw,
        boxsep = 8pt,
        top = 0pt,
        left = 0pt,
        right = 0pt,
        bottom = 0pt,
        borderline~west = {1pt} {-0.5pt} {RPGColorPanelAccent},
        borderline~east = {1pt} {-0.5pt} {RPGColorPanelAccent},
        overlay =
        {
            \foreach \n in { north~east, north~west, south~east, south~west }
            { \draw [ RPGColorPanelAccent, fill = RPGColorPanelAccent ] ( frame.\n ) circle (1.5pt); }
        },
    }
}


%--------------------------------------------------------------------------------------
%   RENDERER

\cs_new_protected:Npn \__rpg_panel_tcolorbox_begin:n #1
{
    \begin{tcolorbox} [ #1 ]
}
\cs_generate_variant:Nn \__rpg_panel_tcolorbox_begin:n { V }

\cs_new_protected:Npn \__rpg_panel_set_defaults:
{
    \__rpg_panel_style_plain:
    \tl_clear:N \l__rpg_panel_title_tl
    \bool_set_false:N \l__rpg_panel_title_bool
}

\cs_new_protected:Npn \__rpg_panel_render:nn #1#2
{
    \group_begin:
        \__rpg_panel_set_defaults:
        \tl_clear:N \l_tmpa_tl

        \tl_if_blank:nF {#1}
        {
            \keys_set_known:nnN { rpg / panel } {#1} \l_tmpa_tl
            \str_if_eq:VnT \l_tmpa_tl { -NoValue- }
                { \tl_clear:N \l_tmpa_tl }
        }

        \tl_set:Nn \l__rpg_panel_box_keys_tl
        {
            frame~hidden,
            boxrule = 0pt,
            breakable,
            enhanced,
            before~skip = 13pt plus 4pt minus 4pt,
            after~skip = 13pt plus 4pt minus 4pt,
            sharp~corners,
            parbox = false,
            before~upper = { },
            code = { \linespread { \l__rpg_panel_line_spread_tl } },
            colback = \l__rpg_panel_color_tl,
            colbacktitle = \l__rpg_panel_color_tl,
            fonttitle = \l__rpg_panel_title_font_tl,
            fontupper = \l__rpg_panel_body_font_tl,
            fontlower = \l__rpg_panel_body_font_tl,
        }

        \bool_if:NT \l__rpg_panel_title_bool
        {
            \tl_put_right:Nn \l__rpg_panel_box_keys_tl
                { title /.expanded = \l__rpg_panel_title_tl, }
        }
        \tl_put_right:NV \l__rpg_panel_box_keys_tl \l__rpg_panel_tcb_keys_tl
        \tl_put_right:NV \l__rpg_panel_box_keys_tl \l_tmpa_tl

        \__rpg_panel_tcolorbox_begin:V \l__rpg_panel_box_keys_tl
            #2
        \end{tcolorbox}
    \group_end:
}




%======================================================================================
%   API

%--------------------------------------------------------------------------------------
%   GENERIC PANEL

% Options are split between rpg/panel keys and raw tcolorbox keys. Supported panel keys:
%   style=plain|comment|sidebar|narration, color=<color>, title=<text>,
%   title-font=<commands>, body-font=<commands>, line-spread=<factor>.
\NewDocumentEnvironment { RPGPanel } { O{} +b }
{
    \__rpg_panel_render:nn {#1} {#2}
}
{ }


%--------------------------------------------------------------------------------------
%   SPECIAL CASES

\NewDocumentEnvironment { RPGNarration } { O{} +b }
{
    \__rpg_panel_render:nn { style = narration, #1 } {#2}
}
{ }

\NewDocumentEnvironment { RPGComment } { O{} m +b }
{
    \__rpg_panel_render:nn { style = comment, title = {#2}, #1 } {#3}
}
{ }

\NewDocumentEnvironment { RPGSideBar } { O{} m +b }
{
    \__rpg_panel_render:nn { style = sidebar, title = {#2}, #1 } {#3}
}
{ }
