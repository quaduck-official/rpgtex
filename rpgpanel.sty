%======================================================================================
%   RPGPANEL
%======================================================================================

\ProvidesExplPackage
    {rpgpanel}
    {2026-07-10}
    {0.1}
    {Unified tcolorbox panels for RPG typesetting}

%======================================================================================
%   SETUP

%--------------------------------------------------------------------------------------
%   REQUIRE

\RequirePackage{xparse}
\RequirePackage{l3keys2e}
\RequirePackage[breakable,skins]{tcolorbox}

\RequirePackage{rpgcolor}
\RequirePackage{rpgfont}

\ExplSyntaxOff
    \usetikzlibrary{calc}
\ExplSyntaxOn




%======================================================================================
%   DATA

%--------------------------------------------------------------------------------------
%   GLOBALS

\bool_new:N \g__rpg_panel_default_floating_bool
\str_new:N  \g__rpg_panel_default_style_str

\bool_gset_false:N \g__rpg_panel_default_floating_bool
\str_gset:Nn       \g__rpg_panel_default_style_str { none }




%--------------------------------------------------------------------------------------
%   LOCALS

\tl_new:N  \l__rpg_panel_accent_tl
\tl_new:N  \l__rpg_panel_background_tl
\tl_new:N  \l__rpg_panel_title_tl
\tl_new:N  \l__rpg_panel_title_font_tl
\tl_new:N  \l__rpg_panel_body_font_tl
\tl_new:N  \l__rpg_panel_line_spread_tl
\tl_new:N  \l__rpg_panel_tcb_keys_tl
\tl_new:N  \l__rpg_panel_box_keys_tl
\bool_new:N \l__rpg_panel_title_bool
\bool_new:N \l__rpg_panel_floating_bool
\str_new:N  \l__rpg_panel_style_str



%======================================================================================
%   OPTIONS

%--------------------------------------------------------------------------------------
%   GLOBAL DEFAULT KEYS

\keys_define:nn { rpg / panel / defaults }
{
    floating .bool_gset:N = \g__rpg_panel_default_floating_bool,
    floating .default:n = true,

    style .choice:,
    style / none .code:n =
        { \str_gset:Nn \g__rpg_panel_default_style_str { none } },
    style / ribbon .code:n =
        { \str_gset:Nn \g__rpg_panel_default_style_str { ribbon } },
    style / bars .code:n =
        { \str_gset:Nn \g__rpg_panel_default_style_str { bars } },
    style .value_required:n = true,
}
\ProcessKeysOptions { rpg / panel / defaults }



%--------------------------------------------------------------------------------------
%   PANEL KEYS

\keys_define:nn { rpg / panel }
{
    accent .tl_set:N = \l__rpg_panel_accent_tl,
    accent .value_required:n = true,

    background .tl_set:N = \l__rpg_panel_background_tl,
    background .value_required:n = true,

    color .meta:n = { background = #1 },
    color .value_required:n = true,

    floating .bool_set:N = \l__rpg_panel_floating_bool,
    floating .default:n = true,

    style .choice:,
    style / none .code:n =
        { \str_set:Nn \l__rpg_panel_style_str { none } },
    style / ribbon .code:n =
        { \str_set:Nn \l__rpg_panel_style_str { ribbon } },
    style / bars .code:n =
        { \str_set:Nn \l__rpg_panel_style_str { bars } },
    style .value_required:n = true,

    title .code:n =
        {
            \tl_set:Nn \l__rpg_panel_title_tl {#1}
            \bool_set_true:N \l__rpg_panel_title_bool
        },
    title .value_required:n = true,

    title-font .tl_set:N = \l__rpg_panel_title_font_tl,
    title-font .value_required:n = true,

    body-font .tl_set:N = \l__rpg_panel_body_font_tl,
    body-font .value_required:n = true,

    fonttitle .meta:n = { title-font = #1 },
    fonttitle .value_required:n = true,

    fontupper .meta:n = { body-font = #1 },
    fontupper .value_required:n = true,

    line-spread .tl_set:N = \l__rpg_panel_line_spread_tl,
    line-spread .value_required:n = true,
}




%======================================================================================
%   CONTROL SEQUENCES

%--------------------------------------------------------------------------------------
%   STYLES

\cs_new_protected:Npn \__rpg_panel_style_none:
{
    \tl_clear:N \l__rpg_panel_tcb_keys_tl
}

\cs_new_protected:Npn \__rpg_panel_style_ribbon:
{
    \tl_set:Nn \l__rpg_panel_tcb_keys_tl
    {
        borderline~north = {1pt} {-0.5pt} {\l__rpg_panel_accent_tl},
        borderline~south = {1pt} {-0.5pt} {\l__rpg_panel_accent_tl},
        fuzzy~shadow = {0mm} {-3.5pt} {-0.5pt} {0.4mm} {\l__rpg_panel_accent_tl!60!white},
        overlay =
        {
            \fill [\l__rpg_panel_accent_tl] ( frame.south~west ) -- ++ (  7pt, 0 ) -- ++ ( 0, -5pt ) -- cycle;
            \fill [\l__rpg_panel_accent_tl] ( frame.north~west ) -- ++ (  7pt, 0 ) -- ++ ( 0,  5pt ) -- cycle;
            \fill [\l__rpg_panel_accent_tl] ( frame.north~east ) -- ++ ( -7pt, 0 ) -- ++ ( 0,  5pt ) -- cycle;
            \fill [\l__rpg_panel_accent_tl] ( frame.south~east ) -- ++ ( -7pt, 0 ) -- ++ ( 0, -5pt ) -- cycle;
        },
    }
}

\cs_new_protected:Npn \__rpg_panel_style_bars:
{
    \tl_set:Nn \l__rpg_panel_tcb_keys_tl
    {
        enhanced~jigsaw,
        borderline~west = {1pt} {-0.5pt} {\l__rpg_panel_accent_tl},
        borderline~east = {1pt} {-0.5pt} {\l__rpg_panel_accent_tl},
        overlay =
        {
            \foreach \n in { north~east, north~west, south~east, south~west }
            { \draw [ \l__rpg_panel_accent_tl, fill = \l__rpg_panel_accent_tl ] ( frame.\n ) circle (1.5pt); }
        },
    }
}

\cs_new_protected:Npn \__rpg_panel_style_apply:
{
    \str_case:Vn \l__rpg_panel_style_str
    {
        { none }   { \__rpg_panel_style_none: }
        { ribbon } { \__rpg_panel_style_ribbon: }
        { bars }   { \__rpg_panel_style_bars: }
    }
}


%--------------------------------------------------------------------------------------
%   RENDERER

\cs_new_protected:Npn \__rpg_panel_tcolorbox_begin:n #1
{
    \begin{tcolorbox} [ #1 ]
}
\cs_generate_variant:Nn \__rpg_panel_tcolorbox_begin:n { V }

\cs_new_protected:Npn \__rpg_panel_set_defaults:
{
    \tl_set:Nn \l__rpg_panel_accent_tl { RPGColorPanelAccent }
    \tl_set:Nn \l__rpg_panel_background_tl { RPGColorPanelBackground }
    \bool_set_eq:NN \l__rpg_panel_floating_bool \g__rpg_panel_default_floating_bool
    \str_set_eq:NN \l__rpg_panel_style_str \g__rpg_panel_default_style_str
    \tl_clear:N \l__rpg_panel_title_tl
    \bool_set_false:N \l__rpg_panel_title_bool
    \tl_set:Nn \l__rpg_panel_title_font_tl { \RPGFontPanelTitle }
    \tl_set:Nn \l__rpg_panel_body_font_tl { \RPGFontPanelBody }
    \tl_set:Nn \l__rpg_panel_line_spread_tl { 1 }
    \tl_clear:N \l__rpg_panel_tcb_keys_tl
}

\cs_new_protected:Npn \__rpg_panel_render:nn #1#2
{
    \group_begin:
        \__rpg_panel_set_defaults:
        \tl_clear:N \l_tmpa_tl

        \tl_if_blank:nF {#1}
        {
            \keys_set_known:nnN { rpg / panel } {#1} \l_tmpa_tl
            \str_if_eq:VnT \l_tmpa_tl { -NoValue- }
                { \tl_clear:N \l_tmpa_tl }
        }

        \__rpg_panel_style_apply:

        \tl_set:Nn \l__rpg_panel_box_keys_tl
        {
            frame~hidden,
            boxrule = 0pt,
            enhanced,
            before~skip = 13pt plus 4pt minus 4pt,
            after~skip = 13pt plus 4pt minus 4pt,
            sharp~corners,
            toptitle = 2pt,
            boxsep = 3pt,
            left = 6pt,
            right = 6pt,
            top = 0pt,
            bottom = 2pt,
            parbox = false,
            before~upper = { },
            code = { \linespread { \l__rpg_panel_line_spread_tl } },
            colback = \l__rpg_panel_background_tl,
            colbacktitle = \l__rpg_panel_background_tl,
            coltitle = \l__rpg_panel_accent_tl,
            fonttitle = \l__rpg_panel_title_font_tl,
            fontupper = \l__rpg_panel_body_font_tl,
            fontlower = \l__rpg_panel_body_font_tl,
        }

        \bool_if:NTF \l__rpg_panel_floating_bool
            { \tl_put_right:Nn \l__rpg_panel_box_keys_tl { float, } }
            { \tl_put_right:Nn \l__rpg_panel_box_keys_tl { breakable, } }

        \bool_if:NT \l__rpg_panel_title_bool
        {
            \tl_put_right:Nn \l__rpg_panel_box_keys_tl
                { title /.expanded = \l__rpg_panel_title_tl, }
        }
        \tl_put_right:NV \l__rpg_panel_box_keys_tl \l__rpg_panel_tcb_keys_tl
        \tl_put_right:NV \l__rpg_panel_box_keys_tl \l_tmpa_tl

        \__rpg_panel_tcolorbox_begin:V \l__rpg_panel_box_keys_tl
            #2
        \end{tcolorbox}
    \group_end:
}




%======================================================================================
%   API

%--------------------------------------------------------------------------------------
%   GENERIC PANEL

\NewDocumentCommand { \RPGPanelSet } { m }
{
    \keys_set:nn { rpg / panel / defaults } { #1 }
}

% Options are split between rpg/panel keys and raw tcolorbox keys. Supported panel keys
% include one-off accent=<color> and background=<color> overrides, floating=<bool>,
% style=none|ribbon|bars, title=<text>, title-font=<commands>, body-font=<commands>,
% and line-spread=<factor>.
\NewDocumentEnvironment { RPGPanel } { O{} +b }
{
    \__rpg_panel_render:nn {#1} {#2}
}
{ }
