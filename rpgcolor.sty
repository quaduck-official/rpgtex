%=============================================================================
% Named-theme system
%=============================================================================

%-----------------------------------------------------------------------------
% Declarations

\prop_new:N \g__rpg_color_themes_prop
\tl_new:N \l__rpg_color_spec_tl

\keys_define:nn { rpg / color / theme }
{
    base      .code:n = { \colorlet      {RPGColorBase} {#1} },
    comment   .code:n = { \colorlet   {RPGColorComment} {#1} },
    sidebar   .code:n = { \colorlet   {RPGColorSidebar} {#1} },
    tablerow  .code:n = { \colorlet  {RPGColorTableRow} {#1} },
    narration .code:n = { \colorlet {RPGColorNarration} {#1} },
    title     .code:n = { \colorlet     {RPGColorTitle} {#1} },
    hrule     .code:n = { \colorlet     {RPGColorHRule} {#1} },
    statblock .code:n = { \colorlet {RPGColorStatBlock} {#1} },
    ribbon    .code:n = { \colorlet    {RPGColorRibbon} {#1} },
    contour   .code:n = { \colorlet   {RPGColorContour} {#1} },
    footer    .code:n = { \colorlet    {RPGColorFooter} {#1} }
}

%-----------------------------------------------------------------------------
% Theme-setting control sequence helpers

% Theme-applying wrapper
\cs_new_protected:Npn \__rpg_color_theme_apply_spec:n #1
{
    \keys_set:nn { rpg / color / theme } { #1 }
}
\cs_generate_variant:Nn \__rpg_color_theme_apply_spec:n { V }

% Theme setter
\cs_new_protected:Npn \__rpg_color_theme_apply:n #1
{
    \prop_get:NnNTF \g__rpg_color_themes_prop { #1 } \l__rpg_color_spec_tl
    {
        \__rpg_color_theme_apply_spec:V \l__rpg_color_spec_tl
    }
    { \PackageError {rpgcolor} {Unknown~theme~'#1'} }
}
\cs_generate_variant:Nn \__rpg_color_theme_apply:n { V }

%-----------------------------------------------------------------------------
% User-facing API

% \RPGColorSet{key=value,...}
\NewDocumentCommand \RPGColorSet { m }
{
    \__rpg_color_theme_apply_spec:n { #1 }
}

% \RPGColorThemeCreate{name}{key=value,...}
\NewDocumentCommand \RPGColorThemeCreate { m m }
{
    \prop_gput:Nnn \g__rpg_color_themes_prop {#1} {#2}
}

% \RPGColorThemeApply{name}
\NewDocumentCommand \RPGColorThemeApply { m }
{
    \__rpg_color_theme_apply:n { #1 }
}


