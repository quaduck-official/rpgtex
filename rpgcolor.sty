%=============================================================================
% Package-option handling
%=============================================================================

% Fallback to default theme
\__rpg_color_theme_apply:n {default}

% Theme name matching as [name] or [theme=name] option
\keys_define:nn { rpg / colors }
{
    theme .code:n =
    { \__rpg_color_theme_apply:n {#1} },

    unknown .code:n =
    { \__rpg_color_theme_apply:V \l_keys_key_tl },
}
\ProcessKeysOptions { rpg / colors }
