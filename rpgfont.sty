\ProvidesExplPackage
    {rpgfont}
    {2026-07-05}
    {0.1}
    {Fonts and styles for RPG typesetting.}

\RequirePackage{Royal}
\RequirePackage{bookman}
\RequirePackage[T1]{fontenc}
\RequirePackage[type1]{gillius2}
\RequirePackage[notext,nomath,nott]{kpfonts}
\RequirePackage{contour}
\RequirePackage{ragged2e}
\RequirePackage{xcolor}

% Load rpgcolor after processing rpgfont options to avoid collisions
\RequirePackage{rpgcolor}


%==============================================================================
% Font and typeface aliases
%==============================================================================

\NewDocumentCommand { \RPGFontFamilySerif } {} { \normalfont }
\NewDocumentCommand { \RPGFontFamilySans } {} { \sffamily }
\NewDocumentCommand { \RPGFontFamilyMono } {} { \ttfamily }
\NewDocumentCommand { \RPGFontFamilyDecorative } {} { \Royal }

\NewDocumentCommand { \RPGFontStyleBodySmall } {} { \small }
\NewDocumentCommand { \RPGFontStyleTitle } {} { \bfseries \scshape }
\NewDocumentCommand { \RPGFontStyleEmphasis } {} { \bfseries \slshape }
\NewDocumentCommand { \RPGFontStyleHeader } {} { \Huge \scshape }


%==============================================================================
% Font definitions
%==============================================================================


