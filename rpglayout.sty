%=======================================================================================
%   RPGLAYOUT
%=======================================================================================

\ProvidesExplPackage
    {rpglayout}
    {2026-07-09}
    {0.1}
    {Page layout controls for RPG typesetting.}

\RequirePackage{l3keys2e}

%=======================================================================================
%   SETUP

%---------------------------------------------------------------------------------------
%   OPTIONS

\tl_new:N \l__rpg_layout_justification_tl
\tl_set:Nn \l__rpg_layout_justification_tl { \RaggedRight }
\bool_new:N \l__rpg_layout_twocolumn_bool


\keys_define:nn { rpg / layout / options }
{
    justification .choice:,
    justification / raggedright .code:n =
        { \tl_set:Nn \l__rpg_layout_justification_tl { \RaggedRight } },
    justification / ragged .code:n =
        { \tl_set:Nn \l__rpg_layout_justification_tl { \RaggedRight } },
    justification / justified .code:n =
        { \tl_clear:N \l__rpg_layout_justification_tl },

    alignment .choice:,
    alignment / raggedright .code:n =
        { \tl_set:Nn \l__rpg_layout_justification_tl { \RaggedRight } },
    alignment / ragged .code:n =
        { \tl_set:Nn \l__rpg_layout_justification_tl { \RaggedRight } },
    alignment / justified .code:n =
        { \tl_clear:N \l__rpg_layout_justification_tl },

    columns .choice:,
    columns / one .code:n =
        { \bool_set_false:N \l__rpg_layout_twocolumn_bool },
    columns / two .code:n =
        { \bool_set_true:N \l__rpg_layout_twocolumn_bool },

    column .choice:,
    column / one .code:n =
        { \bool_set_false:N \l__rpg_layout_twocolumn_bool },
    column / two .code:n =
        { \bool_set_true:N \l__rpg_layout_twocolumn_bool },

    raggedright .code:n =
        { \tl_set:Nn \l__rpg_layout_justification_tl { \RaggedRight } },
    ragged .code:n =
        { \tl_set:Nn \l__rpg_layout_justification_tl { \RaggedRight } },
    justified .code:n =
        { \tl_clear:N \l__rpg_layout_justification_tl },
    onecolumn .code:n =
        { \bool_set_false:N \l__rpg_layout_twocolumn_bool },
    twocolumn .code:n =
        { \bool_set_true:N \l__rpg_layout_twocolumn_bool },
}
\ProcessKeysOptions { rpg / layout / options }

\AtBeginDocument
{
    \bool_if:NT \l__rpg_layout_twocolumn_bool { \twocolumn }
    \RPGFontBody \RPGLayoutJustification
}



%---------------------------------------------------------------------------------------
%   INCLUDE

\RequirePackage{geometry}
\RequirePackage{enumitem}
\RequirePackage{xcolor}
\RequirePackage{rpgcolor}
\RequirePackage{rpgfont}




%=======================================================================================
%   LAYOUT

%---------------------------------------------------------------------------------------
%   LENGTHS
    
\geometry
{%
    hmargin   = .75in, % Left and right margins
    top       = .46in, % Top of text area to top of page
    bottom    = .8in,  % Bottom of text area to bottom of page
    footskip  = .32in, % Bottom of text area to bottom of footer text
    columnsep = .33in, % Space between columns
}


% Set spacing around floats
\setlength{\textfloatsep}{11pt plus 4pt minus 4pt}
\setlength{\intextsep}{11pt plus 4pt minus 4pt}
\setlength{\dbltextfloatsep}{11pt plus 4pt minus 4pt}


% Set paragraph and line spacing
\setlength{\parindent}{1em}
\setlength{\RaggedRightRightskip}{0pt plus 1em}
\setlength{\RaggedRightParindent}{\parindent}


%---------------------------------------------------------------------------------------
%   TOLERANCES
    
% Restrict hyphenation
\tolerance        = 1
\emergencystretch = \maxdimen
\hyphenpenalty    = 10000
\hbadness         = 10000



%---------------------------------------------------------------------------------------
%   ENVIRONMENTS
    
% Customize itemize environment.
\setlist{leftmargin=1em}
\setitemize{noitemsep,topsep=0.5ex,label=\footnotesize{\textbullet}}



%=======================================================================================
%   COMMANDS

\NewDocumentCommand{\RPGLayoutJustification}
    {}
    {\l__rpg_layout_justification_tl}
