%=======================================================================================
%   RPGSECTION
%=======================================================================================

\ProvidesExplPackage
    {rpgsection}
    {2026-07-18}
    {0.1}
    {Explicit RPG sectioning commands.}

\RequirePackage{rpgcolor}
\RequirePackage{rpgfont}



%=======================================================================================
%   SETUP

%---------------------------------------------------------------------------------------
%   VARIABLES

\tl_new:N \l__rpg_section_font_tl
\tl_new:N \l__rpg_section_label_tl
\tl_new:N \l__rpg_section_before_tl
\tl_new:N \l__rpg_section_after_tl
\tl_new:N \l__rpg_section_heading_style_tl
\tl_new:N \l__rpg_section_level_tl
\tl_new:N \l__rpg_section_title_tl
\tl_new:N \l__rpg_section_subheading_tl
\tl_new:N \l__rpg_section_default_level_tl
\tl_new:N \l__rpg_section_numbering_tl
\bool_new:N \l__rpg_section_contour_bool
\bool_new:N \l__rpg_section_toc_bool

\prop_new:N \g__rpg_section_defaults_prop



%---------------------------------------------------------------------------------------
%   MESSAGES

\msg_new:nnn { rpgsection } { unavailable-level }
    { Sectioning~level~'#1'~is~not~available~in~this~document~class. }



%---------------------------------------------------------------------------------------
%   DEFAULTS

\prop_gput:Nnn \g__rpg_section_defaults_prop { part / font }
    { \centering \RPGFontPart }
\prop_gput:Nnn \g__rpg_section_defaults_prop { part / label }
    { \partname\ \__rpg_section_number: }
\prop_gput:Nnn \g__rpg_section_defaults_prop { part / before }
    { 0pt }
\prop_gput:Nnn \g__rpg_section_defaults_prop { part / after }
    { 2ex }

\prop_gput:Nnn \g__rpg_section_defaults_prop { chapter / font }
    { \RPGFontChapter }
\prop_gput:Nnn \g__rpg_section_defaults_prop { chapter / label }
    { \chaptername\ \__rpg_section_number: : }
\prop_gput:Nnn \g__rpg_section_defaults_prop { chapter / before }
    { .3ex }
\prop_gput:Nnn \g__rpg_section_defaults_prop { chapter / after }
    { 2.8ex }

\prop_gput:Nnn \g__rpg_section_defaults_prop { section / font }
    { \RPGFontSection \__rpg_section_justification: }
\prop_gput:Nnn \g__rpg_section_defaults_prop { section / label }
    { \__rpg_section_number: }
\prop_gput:Nnn \g__rpg_section_defaults_prop { section / before }
    { 1.3ex plus .43ex minus .43ex }
\prop_gput:Nnn \g__rpg_section_defaults_prop { section / after }
    { 0pt }

\prop_gput:Nnn \g__rpg_section_defaults_prop { subsection / font }
    { \RPGFontSubsection \__rpg_section_justification: }
\prop_gput:Nnn \g__rpg_section_defaults_prop { subsection / label }
    { \__rpg_section_number: }
\prop_gput:Nnn \g__rpg_section_defaults_prop { subsection / before }
    { 1.4ex plus .47ex minus .47ex }
\prop_gput:Nnn \g__rpg_section_defaults_prop { subsection / after }
    { 1.2ex }

\prop_gput:Nnn \g__rpg_section_defaults_prop { subsubsection / font }
    { \RPGFontSubsubsection \__rpg_section_justification: }
\prop_gput:Nnn \g__rpg_section_defaults_prop { subsubsection / label }
    { \__rpg_section_number: }
\prop_gput:Nnn \g__rpg_section_defaults_prop { subsubsection / before }
    { 2ex plus .67ex minus .67ex }
\prop_gput:Nnn \g__rpg_section_defaults_prop { subsubsection / after }
    { .2ex }

\prop_gput:Nnn \g__rpg_section_defaults_prop { paragraph / font }
    { \RPGFontParagraph }
\prop_gput:Nnn \g__rpg_section_defaults_prop { paragraph / label }
    { \__rpg_section_number: }
\prop_gput:Nnn \g__rpg_section_defaults_prop { paragraph / before }
    { \parskip }
\prop_gput:Nnn \g__rpg_section_defaults_prop { paragraph / after }
    { .333em }

\prop_gput:Nnn \g__rpg_section_defaults_prop { subparagraph / font }
    { \RPGFontSubparagraph }
\prop_gput:Nnn \g__rpg_section_defaults_prop { subparagraph / label }
    { \__rpg_section_number: }
\prop_gput:Nnn \g__rpg_section_defaults_prop { subparagraph / before }
    { \parskip }
\prop_gput:Nnn \g__rpg_section_defaults_prop { subparagraph / after }
    { .333em }

\clist_map_inline:nn
    { part, chapter, section, subsection, subsubsection, paragraph, subparagraph }
{
    \prop_gput:Nnn \g__rpg_section_defaults_prop { #1 / style } { plain }
    \prop_gput:Nnn \g__rpg_section_defaults_prop { #1 / numbering } { none }
    \prop_gput:Nnn \g__rpg_section_defaults_prop { #1 / contour } { false }
}



%=======================================================================================
%   OPTIONS

\cs_generate_variant:Nn \prop_gput:Nnn { Nxn }

\cs_new_protected:Npn \__rpg_section_default_put:nn #1#2
{
    \prop_gput:Nxn \g__rpg_section_defaults_prop
        { \l__rpg_section_default_level_tl / #1 }
        { #2 }
}

\cs_new_protected:Npn \__rpg_section_defaults_set_level:nn #1#2
{
    \tl_set:Nn \l__rpg_section_default_level_tl { #1 }
    \keys_set:nn { rpg / section / defaults / level } { #2 }
}

\keys_define:nn { rpg / section / defaults / level }
{
    font .code:n =
        { \__rpg_section_default_put:nn { font } { #1 } },
    font .value_required:n = true,

    label .code:n =
        { \__rpg_section_default_put:nn { label } { #1 } },
    label .value_required:n = true,

    before-skip .code:n =
        { \__rpg_section_default_put:nn { before } { #1 } },
    before-skip .value_required:n = true,
    before .code:n =
        { \__rpg_section_default_put:nn { before } { #1 } },
    before .value_required:n = true,

    after-skip .code:n =
        { \__rpg_section_default_put:nn { after } { #1 } },
    after-skip .value_required:n = true,
    after .code:n =
        { \__rpg_section_default_put:nn { after } { #1 } },
    after .value_required:n = true,

    style .choice:,
    style / plain .code:n =
        { \__rpg_section_default_put:nn { style } { plain } },
    style / ruled .code:n =
        { \__rpg_section_default_put:nn { style } { ruled } },
    style / banner .code:n =
        { \__rpg_section_default_put:nn { style } { banner } },
    plain .code:n =
        { \__rpg_section_default_put:nn { style } { plain } },
    ruled .code:n =
        { \__rpg_section_default_put:nn { style } { ruled } },
    banner .code:n =
        { \__rpg_section_default_put:nn { style } { banner } },

    numbering .choice:,
    numbering / none .code:n =
        { \__rpg_section_default_put:nn { numbering } { none } },
    numbering / arabic .code:n =
        { \__rpg_section_default_put:nn { numbering } { arabic } },
    numbering / Arabic .code:n =
        { \__rpg_section_default_put:nn { numbering } { arabic } },
    numbering / roman .code:n =
        { \__rpg_section_default_put:nn { numbering } { roman } },
    numbering / Roman .code:n =
        { \__rpg_section_default_put:nn { numbering } { Roman } },
    numbering / alph .code:n =
        { \__rpg_section_default_put:nn { numbering } { alph } },
    numbering / Alph .code:n =
        { \__rpg_section_default_put:nn { numbering } { Alph } },

    contour .choice:,
    contour / true .code:n =
        { \__rpg_section_default_put:nn { contour } { true } },
    contour / false .code:n =
        { \__rpg_section_default_put:nn { contour } { false } },
    contour .default:n = true,
}

\keys_define:nn { rpg / section / style }
{
    font .tl_set:N         = \l__rpg_section_font_tl,
    font .value_required:n = true,

    label .tl_set:N         = \l__rpg_section_label_tl,
    label .value_required:n = true,

    before-skip .tl_set:N         = \l__rpg_section_before_tl,
    before-skip .value_required:n = true,
    before .tl_set:N         = \l__rpg_section_before_tl,
    before .value_required:n = true,

    after-skip .tl_set:N         = \l__rpg_section_after_tl,
    after-skip .value_required:n = true,
    after .tl_set:N         = \l__rpg_section_after_tl,
    after .value_required:n = true,

    style .choice:,
    style / plain .code:n =
        { \tl_set:Nn \l__rpg_section_heading_style_tl { plain } },
    style / ruled .code:n =
        { \tl_set:Nn \l__rpg_section_heading_style_tl { ruled } },
    style / banner .code:n =
        { \tl_set:Nn \l__rpg_section_heading_style_tl { banner } },
    plain .code:n =
        { \tl_set:Nn \l__rpg_section_heading_style_tl { plain } },
    ruled .code:n =
        { \tl_set:Nn \l__rpg_section_heading_style_tl { ruled } },
    banner .code:n =
        { \tl_set:Nn \l__rpg_section_heading_style_tl { banner } },

    numbering .choice:,
    numbering / none .code:n =
        { \tl_set:Nn \l__rpg_section_numbering_tl { none } },
    numbering / arabic .code:n =
        { \tl_set:Nn \l__rpg_section_numbering_tl { arabic } },
    numbering / Arabic .code:n =
        { \tl_set:Nn \l__rpg_section_numbering_tl { arabic } },
    numbering / roman .code:n =
        { \tl_set:Nn \l__rpg_section_numbering_tl { roman } },
    numbering / Roman .code:n =
        { \tl_set:Nn \l__rpg_section_numbering_tl { Roman } },
    numbering / alph .code:n =
        { \tl_set:Nn \l__rpg_section_numbering_tl { alph } },
    numbering / Alph .code:n =
        { \tl_set:Nn \l__rpg_section_numbering_tl { Alph } },

    contour .bool_set:N = \l__rpg_section_contour_bool,
    contour .default:n = true,

    toc .bool_set:N = \l__rpg_section_toc_bool,
}

\keys_define:nn { rpg / section / defaults }
{
    part .code:n =
        { \__rpg_section_defaults_set_level:nn { part } { #1 } },
    chapter .code:n =
        { \__rpg_section_defaults_set_level:nn { chapter } { #1 } },
    section .code:n =
        { \__rpg_section_defaults_set_level:nn { section } { #1 } },
    subsection .code:n =
        { \__rpg_section_defaults_set_level:nn { subsection } { #1 } },
    subsubsection .code:n =
        { \__rpg_section_defaults_set_level:nn { subsubsection } { #1 } },
    paragraph .code:n =
        { \__rpg_section_defaults_set_level:nn { paragraph } { #1 } },
    subparagraph .code:n =
        { \__rpg_section_defaults_set_level:nn { subparagraph } { #1 } },
}



%=======================================================================================
%   INTERNALS

\cs_new:Npn \__rpg_section_justification:
{
    \cs_if_exist:NT \RPGLayoutJustification { \RPGLayoutJustification }
}

\cs_new:Npn \__rpg_section_number:
{
    \str_case:Vn \l__rpg_section_numbering_tl
    {
        { arabic } { \arabic { \l__rpg_section_level_tl } }
        { roman } { \roman { \l__rpg_section_level_tl } }
        { Roman } { \Roman { \l__rpg_section_level_tl } }
        { alph }  { \alph  { \l__rpg_section_level_tl } }
        { Alph }  { \Alph  { \l__rpg_section_level_tl } }
    }
}

\cs_new_protected:Npn \__rpg_section_if_twocolumn:TF #1#2
{
    \cs:w if@twocolumn \cs_end:
        #1
    \else:
        #2
    \fi:
}

\cs_new_protected:Npn \__rpg_section_topnewpage:n #1
{
    \use:c { @topnewpage } [ #1 ]
}

\cs_new_protected:Npn \__rpg_section_defaults_apply:n #1
{
    \prop_get:NnN \g__rpg_section_defaults_prop { #1 / font } \l__rpg_section_font_tl
    \prop_get:NnN \g__rpg_section_defaults_prop { #1 / label } \l__rpg_section_label_tl
    \prop_get:NnN \g__rpg_section_defaults_prop { #1 / before } \l__rpg_section_before_tl
    \prop_get:NnN \g__rpg_section_defaults_prop { #1 / after } \l__rpg_section_after_tl
    \prop_get:NnN \g__rpg_section_defaults_prop { #1 / style } \l__rpg_section_heading_style_tl
    \tl_set:Nn \l__rpg_section_level_tl { #1 }
    \prop_get:NnN \g__rpg_section_defaults_prop { #1 / numbering } \l__rpg_section_numbering_tl
    \prop_get:NnNTF \g__rpg_section_defaults_prop { #1 / contour } \l_tmpa_tl
        {
            \str_if_eq:VnTF \l_tmpa_tl { true }
                { \bool_set_true:N \l__rpg_section_contour_bool }
                { \bool_set_false:N \l__rpg_section_contour_bool }
        }
        { \bool_set_false:N \l__rpg_section_contour_bool }
    \bool_set_true:N \l__rpg_section_toc_bool
}

\cs_new_protected:Npn \__rpg_section_style_apply:
{
    \str_if_eq:VnT \l__rpg_section_heading_style_tl { ruled }
    {
        \vspace { -.3ex }
        \noindent { \color { RPGColorHeader } \rule { \linewidth } { 1pt } }
        \par
    }
}

\cs_new_protected:Npn \__rpg_section_label_display:n #1
{
    \str_if_eq:VnF \l__rpg_section_numbering_tl { none }
    {
        \tl_if_blank:VTF \l__rpg_section_label_tl
            { }
            { \l__rpg_section_label_tl #1 }
    }
}

\cs_new_protected:Npn \__rpg_section_label_display_contoured:n #1
{
    \str_if_eq:VnF \l__rpg_section_numbering_tl { none }
    {
        \tl_if_blank:VF \l__rpg_section_label_tl
            { \exp_args:NV \RPGFontContour \l__rpg_section_label_tl #1 }
    }
}

\cs_new_protected:Npn \__rpg_section_title_display:
{
    \str_if_eq:VnTF \l__rpg_section_heading_style_tl { banner }
    {
        \group_begin:
            \setlength { \fboxsep } { 0pt }
            \colorbox { RPGColorHeader }
            {
                \parbox { \dimexpr\linewidth-2\fboxsep\relax }
                {
                    \vspace { .35ex }
                    \centering
                    \color { RPGColorBackground }
                    \__rpg_section_label_display:n { \space }
                    \l__rpg_section_title_tl
                    \par
                    \vspace { .35ex }
                }
            }
        \group_end:
    }
    {
        \bool_if:NTF \l__rpg_section_contour_bool
        {
            \__rpg_section_label_display_contoured:n { \space }
            \exp_args:NV \RPGFontContour \l__rpg_section_title_tl
        }
        {
            \__rpg_section_label_display:n { \space }
            \tl_use:N \l__rpg_section_title_tl
        }
    }
}

\cs_new_protected:Npn \__rpg_section_title_runin:
{
    \str_if_eq:VnTF \l__rpg_section_heading_style_tl { banner }
    {
        \group_begin:
            \setlength { \fboxsep } { .25ex }
            \colorbox { RPGColorHeader }
            {
                \strut
                \color { RPGColorBackground }
                \__rpg_section_label_display:n { \quad }
                \l__rpg_section_title_tl
            }
        \group_end:
    }
    {
        \__rpg_section_label_display:n { \quad }
        \l__rpg_section_title_tl
    }
}

\cs_new_protected:Npn \__rpg_section_subheading_display:n #1
{
    \IfValueT { #1 }
    {
        \tl_set:Nn \l__rpg_section_subheading_tl { #1 }
        \tl_if_blank:VF \l__rpg_section_subheading_tl
        {
            \noindent { \RPGFontSubheading \l__rpg_section_subheading_tl }
            \par \nobreak
            \vspace { 3pt }
        }
    }
}

\cs_new_protected:Npn \__rpg_section_subheading_runin:n #1
{
    \IfValueT { #1 }
    {
        \tl_set:Nn \l__rpg_section_subheading_tl { #1 }
        \tl_if_blank:VF \l__rpg_section_subheading_tl
            { \space { \RPGFontBody ( { \RPGFontSubheading \l__rpg_section_subheading_tl } ) } }
    }
}

\cs_new_protected:Npn \__rpg_section_counter_step:n #1
{
    \cs_if_exist:cTF { c@#1 }
    {
        \str_if_eq:VnF \l__rpg_section_numbering_tl { none }
        {
            \refstepcounter { #1 }
        }
    }
    {
        \msg_error:nnn { rpgsection } { unavailable-level } { #1 }
    }
}

\cs_new_protected:Npn \__rpg_section_toc_add:nn #1#2
{
    \bool_if:NT \l__rpg_section_toc_bool
    {
        \str_if_eq:VnTF \l__rpg_section_numbering_tl { none }
        {
            \addcontentsline { toc } { #1 } { #2 }
        }
        {
            \addcontentsline { toc } { #1 }
                { \protect\numberline { \__rpg_section_number: } #2 }
        }
    }
}

\cs_new_protected:Npn \__rpg_section_display_block:n #1
{
    \par \addvspace { \l__rpg_section_before_tl }
    \noindent
    { \l__rpg_section_font_tl
        \__rpg_section_title_display:
    }
    \par \nobreak
    \__rpg_section_subheading_display:n { #1 }
    \__rpg_section_style_apply:
    \vspace { \l__rpg_section_after_tl }
}

\cs_new_protected:Npn \__rpg_section_display:nnnn #1#2#3#4
{
    \group_begin:
        \__rpg_section_defaults_apply:n { #1 }
        \keys_set:nn { rpg / section / style } { #2 }
        \tl_set:Nn \l__rpg_section_title_tl { #3 }
        \__rpg_section_counter_step:n { #1 }
        \__rpg_section_toc_add:nn { #1 } { #3 }
        \str_if_eq:nnTF { #1 } { chapter }
        {
            \__rpg_section_if_twocolumn:TF
                { \__rpg_section_topnewpage:n { \__rpg_section_display_block:n { #4 } } }
                { \__rpg_section_display_block:n { #4 } }
        }
        { \__rpg_section_display_block:n { #4 } }
    \group_end:
    \ignorespaces
}

\cs_new_protected:Npn \__rpg_section_runin:nnnn #1#2#3#4
{
    \group_begin:
        \__rpg_section_defaults_apply:n { #1 }
        \keys_set:nn { rpg / section / style } { #2 }
        \tl_set:Nn \l__rpg_section_title_tl { #3 }
        \__rpg_section_counter_step:n { #1 }
        \__rpg_section_toc_add:nn { #1 } { #3 }
        \par \addvspace { \l__rpg_section_before_tl }
        \noindent
        { \l__rpg_section_font_tl
            \__rpg_section_title_runin:
            \__rpg_section_subheading_runin:n { #4 }
            .
        }
        \hspace { \l__rpg_section_after_tl }
    \group_end:
    \ignorespaces
}



%=======================================================================================
%   COMMANDS

\NewDocumentCommand { \RPGSectionSet } { m }
{
    \keys_set:nn { rpg / section / defaults } { #1 }
}

\cs_if_exist:cT { c@part }
{
    \NewDocumentCommand { \RPGPart } { O{} m o }
    {
        \__rpg_section_display:nnnn { part } { #1 } { #2 } { #3 }
    }
}

\cs_if_exist:cT { c@chapter }
{
    \NewDocumentCommand { \RPGChapter } { O{} m o }
    {
        \__rpg_section_display:nnnn { chapter } { #1 } { #2 } { #3 }
    }
}

\cs_if_exist:cT { c@section }
{
    \NewDocumentCommand { \RPGSection } { O{} m o }
    {
        \__rpg_section_display:nnnn { section } { #1 } { #2 } { #3 }
    }
}

\cs_if_exist:cT { c@subsection }
{
    \NewDocumentCommand { \RPGSubsection } { O{} m o }
    {
        \__rpg_section_display:nnnn { subsection } { #1 } { #2 } { #3 }
    }
}

\cs_if_exist:cT { c@subsubsection }
{
    \NewDocumentCommand { \RPGSubsubsection } { O{} m o }
    {
        \__rpg_section_display:nnnn { subsubsection } { #1 } { #2 } { #3 }
    }
}

\cs_if_exist:cT { c@paragraph }
{
    \NewDocumentCommand { \RPGParagraph } { O{} m o }
    {
        \__rpg_section_runin:nnnn { paragraph } { #1 } { #2 } { #3 }
    }
}

\cs_if_exist:cT { c@subparagraph }
{
    \NewDocumentCommand { \RPGSubparagraph } { O{} m o }
    {
        \__rpg_section_runin:nnnn { subparagraph } { #1 } { #2 } { #3 }
    }
}
