%======================================================================================
%   RPGSKILLTREE
%======================================================================================

\ProvidesExplPackage
    {rpgskilltree}
    {2026-07-10}
    {0.5.0}
    {Overlay digraphs on other environments for skill progression}

%======================================================================================
%   SETUP

%--------------------------------------------------------------------------------------
%   REQUIRE

\RequirePackage{xparse}

\ExplSyntaxOff

    \RequirePackage{tikz}
    \usetikzlibrary{tikzmark,arrows.meta}

    % Public default TikZ styles. Override or extend in the document with, for example:
    %   \tikzset{rpgst/default edge/.append style={thin}}
    \tikzset
    {%
        rpgst/default vertex/.style={
            inner sep=1pt,
            outer sep=0pt
        },
        rpgst/default edge/.style={
            ->,
            >=Stealth,
            shorten >=1pt,
            shorten <=1pt
        },
        rpgst/vertex/.style={rpgst/default vertex},
        rpgst/edge/.style={rpgst/default edge}
    }

\ExplSyntaxOn




%======================================================================================
%   DATA

%--------------------------------------------------------------------------------------
%   GLOBALS

\int_new:N \g__rpg_skill_tree_index_int
\tl_new:N  \g__rpg_skill_tree_prefix_tl
\tl_new:N  \g__rpg_skill_tree_edges_tl



%--------------------------------------------------------------------------------------
%   OPTIONS

\keys_define:nn { rpg / skill tree / style }
{
    vertex .code:n =
        { \tikzset { rpgst/vertex/.append~style = {#1} } },
    vertex .value_required:n = true,

    edge .code:n =
        { \tikzset { rpgst/edge/.append~style = {#1} } },
    edge .value_required:n = true,
}



%--------------------------------------------------------------------------------------
%   CONTROL SEQUENCES

\cs_new_protected:Npn \__rpg_skill_tree_reset:
{
    \int_gincr:N \g__rpg_skill_tree_index_int
    \tl_gset:Ne \g__rpg_skill_tree_prefix_tl
        { rpgst-\int_use:N \g__rpg_skill_tree_index_int - }
    \__rpg_skill_tree_clear:
}

\cs_new_protected:Npn \__rpg_skill_tree_clear:
{
    \tl_gclear:N \g__rpg_skill_tree_edges_tl
    \tikzset
    {
        rpgst/vertex/.style = { rpgst/default~vertex },
        rpgst/edge/.style = { rpgst/default~edge }
    }
}


\cs_new_protected:Npn \__rpg_skill_tree_vertex:nn #1#2
{
    \use:x
    {
        \exp_not:N \tikzmarknode
        [ rpgst/vertex ]
        { \tl_use:N \g__rpg_skill_tree_prefix_tl \exp_not:n {#2} }
        { \exp_not:n {#1} }
    }
}

\cs_new_protected:Npn \__rpg_skill_tree_edge:nnn #1#2#3
{
    \use:x
    {
        \exp_not:N \draw
        [ rpgst/edge ]
        ( \tl_use:N \g__rpg_skill_tree_prefix_tl \exp_not:n {#2} )
        to[ \exp_not:n {#1} ]
        ( \tl_use:N \g__rpg_skill_tree_prefix_tl \exp_not:n {#3} );
    }
}




%======================================================================================
%   API

% Apply TikZ option fragments to this skill tree only.
% Usage:
%   \RPGSkillTreeStyle{vertex={draw=red}, edge={thick, draw=red}}
\NewDocumentCommand{\RPGSkillTreeStyle}{m}
{%
    \keys_set:nn { rpg / skill tree / style } {#1}%
}

% Mark a vertex.
% Usage:
%   \RPGSTVertex{name}
%   \RPGSTVertex[$\bullet$]{name}
\NewDocumentCommand{\RPGSTVertex}{O{$\bullet$}m}
{%
    \__rpg_skill_tree_vertex:nn {#1} {#2}%
}

% Store edge commands, but execute them only after the environment closes.
% Multiple calls append to the current tree.
% Usage:
%   \RPGSkillTreeEdges{<\RPGSTEdge{a}{b}...>}
\NewDocumentCommand{\RPGSkillTreeEdges}{+m}
{%
    \tl_gput_right:Nn \g__rpg_skill_tree_edges_tl {#1}%
}

% Draw an edge between two named vertices. Anchor suffixes are allowed:
%   \RPGSTEdge{a.east}{b.west}
% The optional argument is passed to TikZ to[...]:
%   \RPGSTEdge[bend left=20]{a}{b}
%   \RPGSTEdge[out=0,in=180]{a.east}{b.west}
\NewDocumentCommand{\RPGSTEdge}{O{}mm}
{%
    \__rpg_skill_tree_edge:nnn {#1} {#2} {#3}%
}

% Reference the automatically-prefixed TikZ node name in custom paths.
% Usage inside \RPGSkillTreeEdges:
%   \RPGSTDraw{\draw[rpgst/edge] (\RPGSTRef{a}.east) -| (\RPGSTRef{b}.north);}
\NewDocumentCommand{\RPGSTRef}{m}
{%
    \tl_use:N \g__rpg_skill_tree_prefix_tl #1%
}

% Raw TikZ escape hatch for custom routing.
\NewDocumentCommand{\RPGSTDraw}{+m}
{%
    #1%
}

% Environment:
\NewDocumentEnvironment{RPGSkillTree}{}
{%
    \__rpg_skill_tree_reset:%
}
{%
    \begin{tikzpicture}[remember~picture, overlay]
        \tl_use:N \g__rpg_skill_tree_edges_tl
    \end{tikzpicture}%
}
